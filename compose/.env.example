# ═══════════════════════════════════════════════════════════════════════════
#  .env.example  —  .env 의 "견본(템플릿)"입니다. (비밀번호는 비어 있습니다)
# ═══════════════════════════════════════════════════════════════════════════
#
#  [사용법]
#   1) 이 파일을 같은 폴더에 .env 라는 이름으로 복사합니다.
#        PowerShell:  Copy-Item .\compose\.env.example .\compose\.env
#   2) 복사한 .env 를 열어 MSSQL_SA_PASSWORD 등 실제 값을 채웁니다.
#   3) 실제 값이 든 .env 는 Git 에 올리지 않습니다. (.gitignore 에 등록되어 있음)
#      팀에는 이 .env.example 만 공유합니다.
#
#  ※ 규칙: 값의 $ 는 $$ 로, Windows 경로는 슬래시(/)로. 주석은 값 옆이 아니라 윗줄에.
#
#  [아래 인스턴스는 "예시"입니다]  db2019a~c(2019 3개), db2022a~e(2022 5개).
#  실제 환경에 맞게 이름/개수/포트를 바꾸세요. 접두사(DB2019A 등)와 compose.yml 의
#  서비스 키(db2019a 등)는 반드시 짝이 맞아야 합니다.
# ═══════════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════
#  프로젝트 / 네트워크
# ══════════════════════════════════════════════════════════════
COMPOSE_PROJECT_NAME=mssql-farm
NETWORK_NAME=mssql-farm-net
NETWORK_DRIVER=bridge


# ══════════════════════════════════════════════════════════════
#  이미지
# ══════════════════════════════════════════════════════════════
MSSQL_REPO=mcr.microsoft.com/mssql/server
MSSQL_2019_TAG=2019-latest
MSSQL_2022_TAG=2022-latest

# 이미지 버전별 sqlcmd 경로 (헬스체크/백업용). 경로가 바뀌면 여기만 수정.
MSSQL_2019_SQLCMD=/opt/mssql-tools/bin/sqlcmd
MSSQL_2022_SQLCMD=/opt/mssql-tools18/bin/sqlcmd -C


# ══════════════════════════════════════════════════════════════
#  SQL Server 공통 설정
# ══════════════════════════════════════════════════════════════
ACCEPT_EULA=Y

# ★ 필수 ★ sa 비밀번호를 여기에 채우세요.
#   조건: 8자 이상 + 대문자/소문자/숫자/기호 중 3종 이상.
MSSQL_SA_PASSWORD=

MSSQL_PID=Developer
TZ=Asia/Seoul
MSSQL_PORT=1433

# 선택 사항 — 쓰려면 compose.yml 의 대응 줄과 함께 주석 해제
# MSSQL_MEMORY_LIMIT_MB=2048
# MSSQL_AGENT_ENABLED=true

# errorlog(/var/opt/mssql/log)·secrets(/var/opt/mssql/secrets) 도 호스트에 보존하려면 true 로.
# compose.yml 의 각 서비스 volumes 에서 log/secrets 주석 두 줄도 함께 지워야 실제로 마운트됩니다.
# (이 플래그는 start.ps1 이 <DATA_ROOT>/<_DIR>/log·secrets 폴더를 미리 만들지 결정합니다.)
# MOUNT_LOG_SECRETS=true


# ══════════════════════════════════════════════════════════════
#  컨테이너 런타임
# ══════════════════════════════════════════════════════════════
RESTART_POLICY=always
STOP_GRACE_PERIOD=60s

HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=10
HEALTHCHECK_START_PERIOD=60s

LOG_MAX_SIZE=10m
LOG_MAX_FILE=3


# ══════════════════════════════════════════════════════════════
#  백업
# ══════════════════════════════════════════════════════════════
BACKUP_DATABASE=
BACKUP_ROOT=C:/docker/_backup
BACKUP_RETENTION_DAYS=14
BACKUP_STAGING_DIR=/var/opt/mssql/backup


# ══════════════════════════════════════════════════════════════
#  데이터 루트 (Windows 경로도 슬래시 / 사용)
# ══════════════════════════════════════════════════════════════
DATA_ROOT=C:/docker


# ─────────────────────────────────────────────────────────────
#  인스턴스 목록 (예시)
#  한 인스턴스 = 접두사가 같은 3줄 세트입니다.
#    <PREFIX>_NAME : 컨테이너 이름 (= compose.yml 의 hostname/container_name)
#    <PREFIX>_PORT : 호스트에서 접속할 포트 (localhost,<포트> 로 접속)
#    <PREFIX>_DIR  : DATA_ROOT 아래의 데이터 폴더 이름
#  ※ 기존 데이터를 옮겨 붙이는 경우, 컨테이너 이름(_NAME)과 폴더 이름(_DIR)을
#    다르게 둘 수도 있습니다(예: _NAME=Db2019A, _DIR=Db2019A-old). 그럴 땐 임의로 통일하지 마세요.
# ─────────────────────────────────────────────────────────────

# ─────────── 인스턴스: SQL Server 2019 ───────────
DB2019A_NAME=Db2019A
DB2019A_PORT=40000
DB2019A_DIR=Db2019A

DB2019B_NAME=Db2019B
DB2019B_PORT=40100
DB2019B_DIR=Db2019B

DB2019C_NAME=Db2019C
DB2019C_PORT=40200
DB2019C_DIR=Db2019C

# ─────────── 인스턴스: SQL Server 2022 ───────────
DB2022A_NAME=Db2022A
DB2022A_PORT=41000
DB2022A_DIR=Db2022A

DB2022B_NAME=Db2022B
DB2022B_PORT=41100
DB2022B_DIR=Db2022B

DB2022C_NAME=Db2022C
DB2022C_PORT=41200
DB2022C_DIR=Db2022C

DB2022D_NAME=Db2022D
DB2022D_PORT=41300
DB2022D_DIR=Db2022D

DB2022E_NAME=Db2022E
DB2022E_PORT=41400
DB2022E_DIR=Db2022E
